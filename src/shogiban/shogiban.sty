\def\shogiPromotedLance{杏}
\def\shogiKnight{桂}
\def\shogiPromotedKnight{今}
\def\shogiSilver{銀}
\def\shogiPromotedSilver{全}
\def\shogiGold{金}
\def\shogiBishop{角}
\def\shogiPromotedBishop{馬} % Dragon Horse
\def\shogiRook{飛}
\def\shogiPromotedRook{龍} % Dragon King
\def\shogiKingSente{玉}
\def\shogiKingGote{王}
