\usepackage{luatexja}

\usepackage{tikz}

\newif\ifshogiCoordinates
\newif\ifshogiLetterRanks
\newif\ifshogiPieceOutline

% From [this answer by @JasperHabicht](https://tex.stackexchange.com/a/730333/64441).
\pgfkeys{
  /tikz/pics/shogi grid/.style={
    code={
      \pgfmathsetmacro{\correctedBorderScale}{\shogiBorderScale * 0.1}
      \pgfmathsetmacro{\correctedOuterBorderScale}{\shogiOuterBorderScale * 0.1}

      \draw[
        line width = \correctedBorderScale mm,
      ] (0, 0) grid[step = 1]
        (\shogiBoardDimension, \shogiBoardDimension * \shogiHeightMultiplier);

      % Drawn on top of the grid so the outer frame can be scaled
      % independently and stand out from the inner lines.
      \draw[
        line width = \correctedOuterBorderScale mm,
      ] (0, 0) rectangle
        (\shogiBoardDimension, \shogiBoardDimension * \shogiHeightMultiplier);
    },
  },
  /tikz/pics/shogi coordinates/.style={
    code={
      \pgfmathsetmacro{\correctedCoordFontSize}{\shogiFontScale * 4}

      % Files (suji), 9 to 1 left to right, matching the perspective of
      % the player sitting at the bottom (Sente) of a printed diagram.
      \foreach \x/\file in {0/9, 1/8, 2/7, 3/6, 4/5, 5/4, 6/3, 7/2, 8/1} {
        \node[
          font = \fontsize{\correctedCoordFontSize pt}{7.5 pt}\selectfont,
        ] at (\x + 0.5, 9.3) {\file};
      }

      % Ranks (dan), top to bottom: either Roman numerals I-IX, as in
      % Trevor Leggett's books, or letters A-I.
      \ifshogiLetterRanks
        \foreach \y/\rank in {8/A, 7/B, 6/C, 5/D, 4/E, 3/F, 2/G, 1/H, 0/I} {
          \node[
            font   = \fontsize{\correctedCoordFontSize pt}{7.5 pt}\selectfont,
            anchor = west,
          ] at (9.2, \y + 0.5) {\rank};
        }
      \else
        \foreach \y/\rank in {8/I, 7/II, 6/III, 5/IV, 4/V, 3/VI, 2/VII, 1/VIII, 0/IX} {
          \node[
            font   = \fontsize{\correctedCoordFontSize pt}{7.5 pt}\selectfont,
            anchor = west,
          ] at (9.2, \y + 0.5) {\rank};
        }
      \fi
    },
  },
  /tikz/pics/shogi piece/.style={
    code={
      % xscale/yscale cancel the shogi-notation scope's axis flip (see
      % the shogiban environment below), so the piece itself is always
      % drawn in a normal, unflipped local frame regardless of where
      % on the board it was anchored.
      \pgfkeys{
        /tikz/xscale = -1,
        /tikz/yscale = -1,
        /tikz/shift  = {(0.5, 0.5)},
        /phili/shogiban/piece/.cd, #1
      }

      \pgfmathsetmacro{\correctedPieceFontSize}{\shogiFontScale * \shogiPieceFontScale * 7.5}
      \pgfmathsetmacro{\correctedPieceBorderScale}{\shogiPieceBorderScale * 0.3}
      \pgfmathsetmacro{\correctedCountFontSize}{\correctedPieceFontSize * 0.65}

      % The pentagon "house" outline is the vector-diagram look; plain
      % book diagrams instead show just the bare kanji in the square,
      % toggled off via piece/outline = false.
      \ifshogiPieceOutline
        \draw[
          draw       = \shogiPieceColor,
          scale      = \shogiPieceScale,
          rotate     = \shogiPieceRotate,
          line width = \correctedPieceBorderScale mm,
        ]
          (0    , 0.35) --
          (-0.28, 0.23) --
          (-0.3 , -0.3) --
          (0.3  , -0.3) --
          (0.28 , 0.23) --
          cycle;
      \fi
      \node[
        font   = \fontsize{\correctedPieceFontSize pt}{7.5 pt}\selectfont,
        color  = \shogiPieceColor,
        scale  = \shogiPieceScale,
      ] at (0, 0) {\rotatebox{\shogiPieceRotate}{\shogiPieceText}};

      % Used for captured pieces (komadai), where more than one of the
      % same piece is held in hand: draws a small count badge next to
      % the piece. Omitted when count <= 1, since a lone piece in hand
      % is never annotated with a "1" in standard notation.
      \ifnum\shogiPieceCount>1
        \node[
          font  = \fontsize{\correctedCountFontSize pt}{7.5 pt}\selectfont,
          color = \shogiPieceColor,
          scale = \shogiPieceScale,
        ] at (0.5, -0.5) {\shogiPieceCount};
      \fi
    }
  },
  /phili/shogiban/.cd, 
    board dimension/.store in    = \shogiBoardDimension,
    board dimension              = 5 cm,
    height multiplier/.store in  = \shogiHeightMultiplier,
    height multiplier            = 1.2,
    border scale/.store in       = \shogiBorderScale,
    border scale                 = 1.2,
    outer border scale/.store in = \shogiOuterBorderScale,
    outer border scale           = 5.5,
    initial scale/.style         = {
      /tikz/x                    = \shogiBoardDimension / 9 cm * 1 cm,
      /tikz/y                    = \shogiBoardDimension * \shogiHeightMultiplier / 9 cm * 1 cm
    },
    % Real 9x9 cells, instead of the height-multiplier-stretched default.
    square/.style                = { height multiplier = 1 },
    font scale/.store in         = \shogiFontScale,
    font scale                   = 1,
    coordinates/.is if           = shogiCoordinates,
    coordinates                  = true,
    letter ranks/.is if          = shogiLetterRanks,
    letter ranks                 = false,
    % Bundles the square board and bare-kanji pieces typically seen in
    % printed shogi books, as opposed to this package's vector look.
    book style/.style            = { square, piece/outline = false },
    piece/color/.store in        = \shogiPieceColor,
    piece/color                  = black,
    piece/text/.store in         = \shogiPieceText,
    piece/text                   = A,
    piece/font scale/.store in   = \shogiPieceFontScale,
    piece/font scale             = 1,
    piece/scale/.store in        = \shogiPieceScale,
    piece/scale                  = 1,
    piece/border scale/.store in = \shogiPieceBorderScale,
    piece/border scale           = 1,
    piece/rotate/.store in       = \shogiPieceRotate,
    piece/rotate                 = 0,
    piece/count/.store in        = \shogiPieceCount,
    piece/count                  = 1,
    piece/outline/.is if         = shogiPieceOutline,
    piece/outline                = true,
}

\newenvironment{shogiban}[1][]{%
  \begin{tikzpicture}[/phili/shogiban/.cd, #1, initial scale]
    \pic{shogi grid};
    \ifshogiCoordinates
      \pic{shogi coordinates};
    \fi

    % From here on, \pic at (file, rank) follows standard shogi
    % notation instead of this package's internal grid indices: file
    % 1-9 right to left, rank 1-9 top to bottom, so (5, 5) is the
    % centre square and (1, 1) is the top-right corner square. This is
    % done by shifting the origin to the board's top-right corner and
    % flipping both axes; the "shogi piece" pic cancels the flip back
    % out for its own drawing.
    \begin{scope}[
        shift = {(\shogiBoardDimension, \shogiBoardDimension * \shogiHeightMultiplier)},
        x     = -\shogiBoardDimension / 9 cm * 1 cm,
        y     = -\shogiBoardDimension * \shogiHeightMultiplier / 9 cm * 1 cm,
      ]
}{
    \end{scope}
  \end{tikzpicture}%
}

